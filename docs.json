          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/settings",
              "configuration/tasks",
              "configuration/keyboard-shortcuts"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/commands",
              "reference/flamegraph-ui",
              "reference/cli-usage",
              "reference/changelog"

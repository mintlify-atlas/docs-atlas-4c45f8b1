{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Flamegraph for VS Code",
  "theme": "palm",
  "colors": {
    "primary": "#de9924",
    "light": "#364e6f",
    "dark": "#b2c0cf"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/logo-light.png",
    "dark": "/logo/logo-dark.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/rafaelha/vscode-flamegraph"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rafaelha/vscode-flamegraph"
    }
